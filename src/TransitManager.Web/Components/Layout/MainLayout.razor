@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    Bonjour, @context.User.Identity?.Name!
                    <a href="javascript:void(0)" @onclick="Logout">Se déconnecter</a>
                </Authorized>
                <NotAuthorized>
                    <a href="login">Se connecter</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>