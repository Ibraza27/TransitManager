@page "/"

<PageTitle>Accueil - TransitManager</PageTitle>

<h1>Bienvenue sur TransitManager</h1>

<AuthorizeView>
    <Authorized Context="AuthContext">
        <div class="alert alert-success">
            <h4>Connexion réussie !</h4>
            <p>Vous êtes connecté en tant que : <strong>@AuthContext.User.Identity?.Name</strong></p>
            <p>Rôle : <strong>@AuthContext.User.FindFirst(ClaimTypes.Role)?.Value</strong></p>
        </div>
        
        <div class="mt-4">
            <h5>Navigation rapide</h5>
            <div class="d-grid gap-2 d-md-block">
                <AuthorizeView Roles="Administrateur" Context="AdminContext">
                    <Authorized>
                        <a href="clients" class="btn btn-primary me-2">Gérer les clients</a>
                    </Authorized>
                </AuthorizeView>
                <a href="/" class="btn btn-outline-secondary">Actualiser</a>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-info">
            <p>Veuillez vous <a href="login" class="alert-link">connecter</a> pour accéder aux fonctionnalités.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>