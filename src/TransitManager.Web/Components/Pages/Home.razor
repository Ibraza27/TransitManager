@page "/"
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Accueil - TransitManager</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="text-center">
            <h3>Redirection vers les clients...</h3>
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="text-center">
            <h3>Redirection vers la connexion...</h3>
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Console.WriteLine("[Home] Utilisateur authentifié, redirection vers /clients");
            Navigation.NavigateTo("/clients", forceLoad: true);
        }
        else
        {
            Console.WriteLine("[Home] Utilisateur non authentifié, redirection vers /login");
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}